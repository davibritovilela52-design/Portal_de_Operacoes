{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@ops-portal/prisma-client": [
        "packages/prisma-client/index.ts"
      ],
      "@ops-portal/shared": [
        "packages/shared/src/index.ts"
      ],
      "@ops-portal/shared/*": [
        "packages/shared/src/*"
      ]
    }
  }
}
