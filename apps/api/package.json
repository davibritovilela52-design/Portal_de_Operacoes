{
  "name": "@ops-portal/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prestart:dev": "node ../../scripts/clean-dev-artifacts.mjs api",
    "auth:roster:apply": "tsx scripts/provision-better-auth-roster.ts --apply",
    "auth:roster:dry-run": "tsx scripts/provision-better-auth-roster.ts",
    "access:roster:apply": "tsx scripts/provision-access-roster.ts --apply",
    "access:roster:dry-run": "tsx scripts/provision-access-roster.ts",
    "build": "tsc -p tsconfig.json",
    "prebuild": "prisma generate --schema prisma/schema.prisma",
    "pretest": "prisma generate --schema prisma/schema.prisma",
    "legacy-import:apply": "tsx scripts/legacy-yachts-import.ts --apply",
    "legacy-import:dry-run": "tsx scripts/legacy-yachts-import.ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "start": "node dist/src/main.js",
    "start:dev": "npm run build && node dist/src/main.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "tsx": "^4.19.2"
  }
}
